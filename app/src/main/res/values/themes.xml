<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Wave" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#26C6DA</item>
        <item name="colorPrimaryVariant">#00ACC1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#F06292</item>
        <item name="colorSecondaryVariant">#F06292</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Background and surface colors -->
        <item name="android:windowBackground">#E0F7FA</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#37474F</item>

        <!-- Status bar - transparent to let gradient show -->
        <item name="android:statusBarColor">#26C6DA</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Material component overrides -->
        <item name="materialAlertDialogTheme">@style/WaveAlertDialog</item>
        <item name="bottomNavigationStyle">@style/WaveBottomNav</item>
        <item name="floatingActionButtonStyle">@style/WaveFAB</item>
        <item name="textInputStyle">@style/WaveTextInput</item>
    </style>

    <!-- Toolbar title style -->
    <style name="WaveMeshTitleStyle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Alert Dialog style -->
    <style name="WaveAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#37474F</item>
        <item name="buttonBarPositiveButtonStyle">@style/WaveDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/WaveDialogButtonOutlined</item>
        <item name="android:background">@drawable/bg_dialog</item>
    </style>

    <!-- Dialog positive button -->
    <style name="WaveDialogButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#26C6DA</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <!-- Dialog negative button -->
    <style name="WaveDialogButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">#26C6DA</item>
        <item name="android:textColor">#26C6DA</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <!-- Bottom Navigation style -->
    <style name="WaveBottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">#FFFFFF</item>
        <item name="itemIconTint">@drawable/bottom_nav_color</item>
        <item name="itemTextColor">@drawable/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- FAB style -->
    <style name="WaveFAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">#26C6DA</item>
        <item name="tint">#FFFFFF</item>
        <item name="elevation">6dp</item>
    </style>

    <!-- TextInput style -->
    <style name="WaveTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#FFFFFF</item>
        <item name="boxStrokeColor">#4DD0E1</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">#00ACC1</item>
        <item name="android:textColorHint">#B0BEC5</item>
    </style>

</resources>